            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"],
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"}
              ]
            },
            "description": "Returns a paginated list of users. Requires ADMIN role. Passwords are NOT included in the response."
          }
        },
        {
          "name": "Get user by ID (own or ADMIN)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "1"]
            },
            "description": "Returns user details. Accessible by the user themselves or an ADMIN. No password returned."
          }
        },
