{
  "info": {
    "name": "OneTap eLeague API",
    "_postman_id": "onetap-eleague-api-v1",
    "description": "Complete REST API collection for OneTap eLeague (Práctica 3 SSDD).\n\n**Setup:**\n1. Set the `baseUrl` variable to `https://localhost:8443` (or your deployed URL).\n2. Call `POST /api/v1/auth/login` to get a JWT token.\n3. The `token` variable is used automatically in authenticated requests.\n\n**Credentials (default):**\n- Admin: `admin` / `pass123`\n- User:  `user` / `pass123`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:8443",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Login and registration endpoints",
      "item": [
        {
          "name": "Login (get JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    var raw = json.token.replace('Bearer ', '');",
                  "    pm.collectionVariables.set('token', raw);",
                  "    console.log('Token saved.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"pass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "login"]
            },
            "description": "Authenticates a user and returns a JWT Bearer token. The test script automatically saves the token to the `token` collection variable."
          }
        },
        {
          "name": "Register new user",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"nickname\": \"testuser\",\n  \"email\": \"test@urjc.es\",\n  \"university\": \"URJC\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "auth", "register"]
            },
            "description": "Registers a new user. Returns 201 Created with a JWT token."
          }
        }
      ]
    },
    {
      "name": "Tournaments",
      "description": "Tournament CRUD endpoints",
      "item": [
        {
          "name": "List tournaments (paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tournaments?page=0&size=10&game=&state=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tournaments"],
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"},
                {"key": "game", "value": "", "description": "Filter by game (optional)"},
                {"key": "state", "value": "", "description": "Filter by state (optional)"}
              ]
            },
            "description": "Returns a paginated list of tournaments. Supports optional filters: `game` and `state`. Public endpoint."
          }
        },
        {
          "name": "Get tournament by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tournaments/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tournaments", "1"]
            },
            "description": "Returns the details of a specific tournament. Public endpoint."
          }
        },
        {
          "name": "Create tournament (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Spring Championship 2025\",\n  \"game\": \"League of Legends\",\n  \"platform\": \"PC\",\n  \"mode\": \"5v5\",\n  \"maxTeams\": 16,\n  \"startDate\": \"2025-06-01\",\n  \"description\": \"Annual spring tournament for URJC students.\",\n  \"rules\": \"Standard competitive ruleset.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tournaments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tournaments"]
            },
            "description": "Creates a new tournament. Requires ADMIN role. Returns 201 Created with Location header."
          }
        },
        {
          "name": "Update tournament (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Spring Championship 2025 - Updated\",\n  \"game\": \"League of Legends\",\n  \"platform\": \"PC\",\n  \"mode\": \"5v5\",\n  \"maxTeams\": 32,\n  \"startDate\": \"2025-06-15\",\n  \"state\": \"Active\",\n  \"description\": \"Updated description.\",\n  \"rules\": \"Updated rules.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tournaments/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tournaments", "1"]
            },
            "description": "Updates an existing tournament. Requires ADMIN role."
          }
        },
        {
          "name": "Delete tournament (ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/v1/tournaments/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tournaments", "1"]
            },
            "description": "Deletes a tournament by ID. Requires ADMIN role. Returns 204 No Content."
          }
        },
        {
          "name": "Get tournament PDF",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tournaments/1/pdf",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tournaments", "1", "pdf"]
            },
            "description": "Downloads the tournament summary as a PDF file. Calls the utility-service internally."
          }
        },
        {
          "name": "Get tournament image",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tournaments/1/image",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tournaments", "1", "image"]
            },
            "description": "Returns the tournament banner image."
          }
        }
      ]
    },
